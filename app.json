{
  "expo": {
    "name": "MooveFretes Transportadora",
    "slug": "moovefretes-transportadora",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.moovefretes.transportadora"
    },
    "android": {
      "package": "com.moovefretes.transportadora",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.VIBRATE",
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "MooveFretes precisa da sua localização para mostrar fretes próximos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#253663",
          "sounds": [],
          "androidMode": "default",
          "androidCollapsedTitle": "MooveFretes"
        }
      ]
    ],
    "scheme": "moovefretes",
    "extra": {
      "eas": {
        "projectId": "c7959cbc-4095-4955-a1ee-4a27a9a70bbe"
      }
    },
    "owner": "oclaytonaraujos"
  }
}
